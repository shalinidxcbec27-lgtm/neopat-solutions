#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    int i,len,min=0,max=0;
    char str1[30],str2[30];
    cin>>str1;
    cin>>str2;
    len=strlen(str1);
    for(i=0;i<len;i++)
    {
        if(str1[i]!=str2[i])
        {
            if((str1[i]!=63)&&(str2[i]!=63))
            {
                min++;
                max++;
            }
            else
            max++;
        }
        else if((str1[i]==str2[i])&&(str1[i]==63))
        max++;
    }
    cout<<min<<" "<<max;
    return 0;
}
