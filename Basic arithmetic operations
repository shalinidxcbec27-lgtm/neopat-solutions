#include<iostream>
using namespace std;
int main(){
    int num1,num2;
    char ch;
    cin>>num1>>num2;
    cin>>ch;
    switch(ch)
    {
        case '+':
        cout<<"The addition of the given numbers is "<<(num1+num2)<<".";
        break;
        case '-':
        cout<<"The subtraction of the given numbers is "<<(num1-num2)<<".";
        break;
        case '*':
        cout<<"The multiplication of the given numbers is "<<(num1*num2)<<".";
        break;
        case '/':
        cout<<"The division of the given numbers is "<<(num1/num2)<<".";
        break;
    default:
    cout<<"Invalid Operation";
    }
    
    }
